# Setup instructions:
# 1. Copy this file to .env
# 2. Choose one LLM runtime for Step 5:
#    - Local OpenAI-compatible runtime (default)
#    - Ollama (optional)
#    - OpenAI cloud (optional)
# 3. For OAuth2 authentication, follow config/README.md to create client_secrets.json
#    No Gmail username/password needed.

# ------------------------------------------------------------
# LLM runtime selection
# ------------------------------------------------------------
LLM_PROVIDER=local
# LLM_PROVIDER=ollama
# LLM_PROVIDER=openai

# Local OpenAI-compatible runtime
# api: openai-completions
LOCAL_BASE_URL=http://0.0.0.0:30000/v1
LOCAL_API_KEY=not-needed
LOCAL_MODEL=qwen3.5-9b

# Ollama (optional)
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_API_KEY=ollama-local
# OLLAMA_MODEL=lukey03/qwen3.5-9b-abliterated-vision

# OpenAI cloud (optional)
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o-mini

# Optional: Override default OAuth2 file paths
# OAUTH_CLIENT_SECRETS_PATH=config/client_secrets.json
# OAUTH_TOKEN_PATH=config/token.json
# OAUTH_PORT=8080  # Change if port 8080 is already in use

# Email filtering configuration
# TARGET_SENDERS=billing@apple.com,receipts@uber.com,no-reply@amazon.com
# TARGET_KEYWORDS=receipt,invoice,billing,收據,發票

# Bank passwords for encrypted PDF statements (Step 4+)
# Simple format: comma-separated list of passwords to try in order
# BANK_PASSWORDS=password1,password2,password3
# Legacy key=value format also supported for backward compatibility
# BANK_PASSWORDS=hsbc_sg=A123456789,hsbc_tw=B987654321,fubon=C111111111,esunbank=D222222222
# Passwords will be tried in order until one works or all fail

# Issue #24: Large transaction list parsing enhancements
# Enable adaptive chunking for large PDF statements (40+ transactions)
# ENABLE_ADAPTIVE_CHUNKING=true
# Maximum chunk size in characters (default: 3500)
# MAX_CHUNK_SIZE=3500
# Minimum transactions per chunk (default: 5)
# MIN_TRANSACTIONS_PER_CHUNK=5
# Force chunking above this text length (default: 8000)
# FORCE_CHUNKING_TEXT_LENGTH=8000

# HSBC OCR fallback safety
# Require Traditional Chinese language pack in tesseract before applying OCR description overwrite
# HSBC_OCR_REQUIRE_CHI_TRA=true
