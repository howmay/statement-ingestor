# Setup instructions:
# 1. Copy this file to .env
# 2. Add your Gmail email address
# 3. Create an App Password in your Google Account Security settings
#    (Requires 2-Step Verification to be enabled)
# 4. For LLM parsing, add your OpenAI API key

GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password
OPENAI_API_KEY=your_openai_api_key_here

# Optional: For Gmail API (OAuth2/Service Account) authentication
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account-key.json
# Or provide OAuth2 client ID/secret via google-auth library
